{
  "name": "@quasar/quasar-app-extension-testing-unit-vitest",
  "version": "1.2.3",
  "license": "MIT",
  "description": "A Quasar App Extension for running tests with Vitest",
  "contributors": [
    "Paolo Caleffi",
    "Evert van der Weit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/quasarframework/quasar-testing"
  },
  "scripts": {
    "build": "rimraf dist && tsc --declaration --declarationDir dist/types",
    "build:local": "yarn install && yarn build && rimraf node_modules",
    "deploy:alpha": "yarn build && yarn publish --tag alpha",
    "deploy:beta": "yarn build && yarn publish --tag beta",
    "deploy:latest": "yarn build && yarn publish --tag latest"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/main.js",
  "typings": "dist/types/main.d.ts",
  "engines": {
    "node": "^30 || ^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 9.5",
    "yarn": ">= 1.22.19"
  },
  "dependencies": {
    "happy-dom": "^15.0.0",
    "lodash-es": "^4.17.21",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependenciesComments": {
    "rimraf": "Other packages in the monorepo require node <=18, so let's not update it to continue supporting lower versions. Updating with prevent installation of those packages"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@vitest/ui": "^3.1.2",
    "@vue/test-utils": "^2.4.6",
    "quasar": "^2.18.1",
    "rimraf": "^5.0.5",
    "vitest": "^3.1.2",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "@vitest/ui": "^1.1.0 || ^2.0.0 || ^3.0.0",
    "@vue/test-utils": "^2.4.3",
    "quasar": "^2.12.7",
    "vitest": "^1.6.1 || ^2.1.9 || ^3.0.5",
    "vue": "^3.3.4"
  },
  "peerDependenciesMeta": {
    "@vitest/ui": {
      "optional": true
    }
  }
}